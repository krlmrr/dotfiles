// Zed keymap (Linux)
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
    {
        "bindings": {
            "ctrl-j": "menu::SelectNext",
            "ctrl-k": "menu::SelectPrevious",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-shift-b": "workspace::ToggleLeftDock",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-b": "workspace::ToggleRightDock",
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-t": "terminal_panel::Toggle",
            "ctrl-e": "project_panel::ToggleFocus",
            "ctrl-g": "git_panel::ToggleFocus",
        },
    },
    {
        "context": "Editor && !menu",
        "bindings": {
            "ctrl-t": "terminal_panel::Toggle",
        },
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-t": "terminal_panel::Toggle",
        },
    },
    {
        "context": "vim_mode == normal && !menu",
        "bindings": {
            "ctrl-e": "project_panel::ToggleFocus",
            "ctrl-g": "git_panel::ToggleFocus",
        },
    },
    {
        "context": "ProjectPanel",
        "bindings": {
            "ctrl-e": "workspace::ToggleRightDock",
        },
    },
    {
        "context": "GitPanel",
        "bindings": {
            "ctrl-g": "workspace::ToggleRightDock",
        },
    },
    {
        "context": "Editor",
        "bindings": {
            "ctrl-;": [
                "projects::OpenRecent",
                {
                    "create_new_window": false,
                },
            ],
        },
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-;": [
                "projects::OpenRecent",
                {
                    "create_new_window": false,
                },
            ],
        },
    },
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-;": [
                "projects::OpenRecent",
                {
                    "create_new_window": false,
                },
            ],
        },
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-n": "workspace::NewTerminal"
        }
    },
    {
        // Fire ctrl-w immediately to close the active tab. vim mode treats ctrl-w
        // as a window-command prefix (ctrl-w h/j/k/l/v/s/...), which makes Zed
        // wait for a follow-up keystroke before firing. Nullify those chords so
        // there's nothing to wait for; vim splits via ctrl-w are sacrificed.
        "context": "vim_mode == normal || vim_mode == visual || vim_mode == insert",
        "bindings": {
            "ctrl-w": "pane::CloseActiveItem",
            "ctrl-w h": null,
            "ctrl-w j": null,
            "ctrl-w k": null,
            "ctrl-w l": null,
            "ctrl-w shift-h": null,
            "ctrl-w shift-j": null,
            "ctrl-w shift-k": null,
            "ctrl-w shift-l": null,
            "ctrl-w v": null,
            "ctrl-w s": null,
            "ctrl-w q": null,
            "ctrl-w c": null,
            "ctrl-w o": null,
            "ctrl-w w": null,
            "ctrl-w x": null,
            "ctrl-w =": null,
            "ctrl-w -": null,
            "ctrl-w +": null,
            "ctrl-w >": null,
            "ctrl-w <": null,
            "ctrl-w |": null,
            "ctrl-w _": null
        }
    }
]
