title = "  "
theme = dark:One Half Dark,light:artisan
palette = 6=#7aa2f7
palette = 14=#7aa2f7

font-family = MonoLisa
font-style = Medium
font-style-italic = Medium Italic
font-style-bold = Medium
font-style-bold-italic = Medium Italic
window-padding-balance = true

window-save-state = always

cursor-style = bar
confirm-close-surface = false
shell-integration-features = sudo
keybind = shift+enter=text:\x1b\r
# ctrl+shift+w is hijacked by GTK on Linux (closes whole window even when
# bound to close_surface — see ghostty discussions #5538, #9026). Use
# ctrl+shift+x instead, which has no GTK default and reliably closes splits.
keybind = ctrl+shift+x=close_surface
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right

# Custom
split-divider-color = #2C313A
