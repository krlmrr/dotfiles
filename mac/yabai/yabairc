#!/usr/bin/env sh

# Scripting addition (requires SIP partially disabled)
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
yabai -m signal --add event=system_woke action="yabai -m rule --apply"
sudo yabai --load-sa
yabai -m config menubar_opacity 0.0

# Reserve space for sketchybar
yabai -m config external_bar all:0:0

# BSP layout (binary space partitioning - auto alternates h/v splits)
yabai -m config layout bsp

# New window spawns to the right or bottom (auto-alternates)
yabai -m config window_placement second_child

# Gaps
yabai -m config top_padding 6
yabai -m config bottom_padding 16
yabai -m config left_padding 12
yabai -m config right_padding 12
yabai -m config window_gap 10

# Mouse
yabai -m config mouse_follows_focus off
yabai -m config focus_follows_mouse autofocus
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# Window rules
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Finder$" title="^(Copy|Move|Delete|Connecting)" manage=off
yabai -m rule --add app="^Logi Options\+$" manage=off
yabai -m rule --add app="^Herd$" manage=off
yabai -m rule --add app="^PhpStorm$" title="^(Settings|Create New Branch|Push Commits to .+|Rollback Changes|Update Project)$" manage=off
yabai -m rule --add app="^Zed$" title="Settings$" manage=off

# Workspace 2 floating
yabai -m space 2 --label chat
yabai -m config --space 2 layout float
yabai -m signal --add event=window_created action="[ \$(yabai -m query --windows --window \$YABAI_WINDOW_ID | jq -r '.space') -eq 2 ] && yabai -m window \$YABAI_WINDOW_ID --sub-layer normal"

# App assignments
yabai -m rule --add app="^Spark Desktop$" space=1
yabai -m rule --add app="^Mail$" space=1
yabai -m rule --add app="^Slack$" space=2
yabai -m rule --add app="^Discord$" space=2
yabai -m rule --add app="^Telegram$" space=2
yabai -m rule --add app="^Messages$" space=2
yabai -m rule --add app="^Microsoft Teams$" space=2
yabai -m signal --add event=window_created app="^Microsoft Teams$" action="yabai -m window \$YABAI_WINDOW_ID --space 2"
yabai -m rule --add app="^Tuple$" space=2 manage=off

yabai -m space 4 --label code
yabai -m rule --add app="^Ghostty$" space=4
yabai -m rule --add app="^Zen$" space=4
yabai -m rule --add app="^Zed$" space=4

# Start on workspace 4
yabai -m space --focus 4

echo "yabai configuration loaded"
