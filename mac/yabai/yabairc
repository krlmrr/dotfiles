#!/usr/bin/env sh
# Single-file yabai config + dynamic layout. Invoked two ways:
#   • no arg  → yabai runs this on load: full config + signal registration
#   • "<cmd>" → signal actions re-invoke this file to run one function
# Everything logs to /tmp/yabai.log so there's one place to watch.

LOG=/tmp/yabai.log
SELF="$HOME/Code/dotfiles/mac/yabai/yabairc"
LAPTOP_W=2056          # MBP 16" reports 2056x1329 in yabai points; used to
LAPTOP_H=1329          # tell the laptop panel from an external display.
SIG_FILE=/tmp/yabai_display_sig

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') [$1] ${2:-}" >> "$LOG"; }

# True when the scripting addition can load (SIP off, or the partial config with
# filesystem protections disabled). Full SIP -> false -> tiling-only mode.
sa_capable() {
  s=$(csrutil status 2>/dev/null)
  echo "$s" | grep -qi 'status: disabled' && return 0
  echo "$s" | grep -qi 'Filesystem Protections: disabled'
}

# ------------------------------------------------------------------ helpers
move() {  # move every window of app $1 to space $2 (leaves the sticky PiP popout alone)
  yabai -m query --windows 2>/dev/null \
    | jq -r --arg a "$1" '.[]|select(.app==$a and .title!="Picture-in-Picture")|.id' \
    | xargs -I{} yabai -m window {} --space "$2" 2>/dev/null
}

# The editor set — whichever of these are open share the editor slot/layout.
# THE one list to edit when editors change; editor_sel (jq predicate) and
# EDITOR_RE (signal regex) are generated from it.
# App names must be single words with no regex metacharacters.
EDITOR_APPS="Zed Code"
editor_sel=""
for a in $EDITOR_APPS; do editor_sel="$editor_sel${editor_sel:+ or }.app==\"$a\""; done
editor_sel="($editor_sel)"
EDITOR_RE="^($(echo "$EDITOR_APPS" | tr ' ' '|'))\$"

# The browser set — whichever is open owns the top-left slot ("single browser
# only": the first open one is the slot; extras get adopted). Multi-word names
# (e.g. "Google Chrome") mean this list is NEWLINE-delimited, not space-split
# like EDITOR_APPS. browser_sel (jq) and BROWSER_RE (signal regex) are generated.
BROWSER_APPS='Zen
Google Chrome
Safari
Arc'
browser_sel=""; browser_alt=""
while IFS= read -r a; do
  [ -n "$a" ] || continue
  browser_sel="$browser_sel${browser_sel:+ or }.app==\"$a\""
  browser_alt="$browser_alt${browser_alt:+|}$a"
done <<EOF
$BROWSER_APPS
EOF
browser_sel="($browser_sel)"
BROWSER_RE="^($browser_alt)\$"

move_editors() {  # move every editor window to space $1 (leaves the sticky PiP popout alone)
  yabai -m query --windows 2>/dev/null \
    | jq -r ".[]|select($editor_sel and .title!=\"Picture-in-Picture\")|.id" \
    | xargs -I{} yabai -m window {} --space "$1" 2>/dev/null
}

move_browsers() {  # move every browser window to space $1 (leaves the sticky PiP popout alone)
  yabai -m query --windows 2>/dev/null \
    | jq -r ".[]|select($browser_sel and .title!=\"Picture-in-Picture\")|.id" \
    | xargs -I{} yabai -m window {} --space "$1" 2>/dev/null
}

editor_ids() {  # ids of all STANDARD editor windows, in query order (first = base)
  yabai -m query --windows 2>/dev/null \
    | jq -r ".[]|select($editor_sel and .subrole==\"AXStandardWindow\" and .title!=\"Picture-in-Picture\")|.id"
}

win_id() {  # id of first STANDARD window of app $1 (exact name; skips phantoms
            # and the "Picture-in-Picture" popout, which reports AXStandardWindow)
  yabai -m query --windows 2>/dev/null \
    | jq -r --arg a "$1" '.[]|select(.app==$a and .subrole=="AXStandardWindow" and .title!="Picture-in-Picture")|.id' | head -1
}

browser_id() {  # id of first STANDARD browser window (the top-left slot occupant;
                # skips phantoms and the "Picture-in-Picture" popout)
  yabai -m query --windows 2>/dev/null \
    | jq -r ".[]|select($browser_sel and .subrole==\"AXStandardWindow\" and .title!=\"Picture-in-Picture\")|.id" | head -1
}

external_idx() {  # index of the non-laptop display, empty when undocked
  yabai -m query --displays 2>/dev/null \
    | jq -r --argjson w "$LAPTOP_W" --argjson h "$LAPTOP_H" \
      '.[]|select(.frame.w!=$w or .frame.h!=$h)|.index' | head -1
}

editor_space() {  # space where editors live: 3rd space of the external display
                  # when docked, space 4 laptop-only
  ext=$(external_idx)
  [ -z "$ext" ] && { echo 4; return; }
  yabai -m query --spaces --display "$ext" 2>/dev/null | jq -r '.[2].index // empty'
}

adopt() {  # window_created (any app): tuck a stray under the editor on the
           # editor space. Warp is tree-only, so it works SIP-on unfocused.
  id="$1"; [ -n "$id" ] || return 0
  win=$(yabai -m query --windows --window "$id" 2>/dev/null); [ -n "$win" ] || return 0
  app=$(echo "$win" | jq -r '.app')
  # Never adopt trio members: editors + Ghostty by app; the slot browser by id
  # (a SECOND browser window has a different id and DOES get adopted).
  case " $EDITOR_APPS Ghostty " in *" $app "*) return 0 ;; esac
  [ "$id" = "$(browser_id)" ] && return 0
  echo "$win" | jq -e '.subrole=="AXStandardWindow" and .title!="Picture-in-Picture" and ."is-floating"==false' >/dev/null || return 0
  target=$(editor_space); [ -n "$target" ] || return 0
  [ "$(echo "$win" | jq -r '.space')" = "$target" ] || return 0
  ed=$(yabai -m query --windows --space "$target" 2>/dev/null \
    | jq -r ".[]|select($editor_sel and .subrole==\"AXStandardWindow\" and .title!=\"Picture-in-Picture\")|.id" | head -1)
  [ -n "$ed" ] || return 0
  log adopt "adopt: $app ($id) -> under editor $ed on space $target"
  warp_to "$id" "$ed" south
}

floating()     { yabai -m query --windows --window "$1" 2>/dev/null | jq -r '."is-floating"'; }
ensure_tiled() { [ "$(floating "$1")" = "true" ]  && yabai -m window "$1" --toggle float 2>/dev/null; return 0; }
pair_geom() {  # echo "sx sy tx ty" (floored) for window ids $1 $2; empty on miss
  yabai -m query --windows 2>/dev/null | jq -r --argjson s "$1" --argjson t "$2" '
      (map(select(.id==$s))[0].frame) as $a
    | (map(select(.id==$t))[0].frame) as $b
    | "\($a.x|floor) \($a.y|floor) \($b.x|floor) \($b.y|floor)"' 2>/dev/null
}

warp_to() {  # warp $1 onto $2 so it lands $3 (west/east/north/south) of it.
             # No --insert priming: the armed point survives successful warps and
             # same-dir --insert toggles it off (verified live), so arming is a
             # parity coin flip. Warp, then verify geometry and repair with
             # --toggle split (wrong axis) and --swap (wrong order) instead.
  yabai -m window "$1" --warp "$2" 2>/dev/null || { log warp "warp $1 onto $2 failed"; return 1; }
  geom=$(pair_geom "$1" "$2"); [ -n "$geom" ] || return 1
  sx=$(echo "$geom" | cut -d' ' -f1); sy=$(echo "$geom" | cut -d' ' -f2)
  tx=$(echo "$geom" | cut -d' ' -f3); ty=$(echo "$geom" | cut -d' ' -f4)
  case "$3" in
    west|east)   [ "$sy" -ne "$ty" ] && yabai -m window "$1" --toggle split 2>/dev/null ;;
    north|south) [ "$sx" -ne "$tx" ] && yabai -m window "$1" --toggle split 2>/dev/null ;;
  esac
  geom=$(pair_geom "$1" "$2"); [ -n "$geom" ] || return 1
  sx=$(echo "$geom" | cut -d' ' -f1); sy=$(echo "$geom" | cut -d' ' -f2)
  tx=$(echo "$geom" | cut -d' ' -f3); ty=$(echo "$geom" | cut -d' ' -f4)
  swap=0
  case "$3" in
    west)  [ "$sx" -gt "$tx" ] && swap=1 ;;
    east)  [ "$sx" -lt "$tx" ] && swap=1 ;;
    north) [ "$sy" -gt "$ty" ] && swap=1 ;;
    south) [ "$sy" -lt "$ty" ] && swap=1 ;;
  esac
  [ "$swap" = 1 ] && yabai -m window "$1" --swap "$2" 2>/dev/null
  return 0
}

# True when the editor layout already matches the desired target on space $1:
#   editor open  -> browser-TL / Ghostty-BL (stacked left) / editor full-R
#   editor closed-> browser | Ghostty side by side (browser left)
# 0-or-1 editors present is trivially correct (nothing to arrange).
external_correct() {
  yabai -m query --windows --space "$1" 2>/dev/null | jq -e '
      (map(select(.subrole=="AXStandardWindow" and .title!="Picture-in-Picture"))) as $w
    | ($w|map(select('"$browser_sel"'))|first) as $browser
    | ($w|map(select('"$editor_sel"'))|first)  as $ed
    | ($w|map(select(.app=="Ghostty"))|first)  as $gho
    | ([$browser,$ed,$gho]|map(select(.!=null))|length) as $n
    | if $n <= 1 then true
      elif $ed then
        ($browser and $gho)
        and ($ed.frame.x > $browser.frame.x)
        and (($browser.frame.x|floor) == ($gho.frame.x|floor))
        and ($browser.frame.y < $gho.frame.y)
      else
        ($browser and $gho)
        and ($browser.frame.x < $gho.frame.x)
        and (($browser.frame.y|floor) == ($gho.frame.y|floor))
      end
  ' >/dev/null 2>&1
}

# ------------------------------------------------------------- place editors
# Acts on whichever editors are OPEN (none required). Deterministic warp
# rebuild; skips entirely when the layout is already correct.
place_editors() {
  trigger="${1:-startup}"
  if [ -z "$(external_idx)" ]; then
    log place "place($trigger): laptop only -> browsers:3 editors:4 Ghostty:5"
    move_browsers 3; move_editors 4; move Ghostty 5
    return
  fi

  target=$(editor_space)
  [ -z "$target" ] && { log place "place($trigger): external present, no 3rd space"; return; }

  eds=$(editor_ids); ed=$(echo "$eds" | head -1); browser=$(browser_id); gho=$(win_id Ghostty)
  for id in $eds $browser $gho; do [ -n "$id" ] && yabai -m window "$id" --space "$target" 2>/dev/null; done

  if external_correct "$target"; then
    log place "place($trigger): trio correct on space $target — skip rebuild"
  else
    # Warp-based rebuild: tree-only ops, no space focus needed — runs in both SIP modes.
    for id in $ed $browser $gho; do ensure_tiled "$id"; done
    if [ -n "$ed" ]; then
      log place "place($trigger): rebuild stacked (editor open) — browser TL / Ghostty BL / editor R"
      [ -n "$browser" ] && warp_to "$browser" "$ed" west
      [ -n "$gho" ] && warp_to "$gho" "${browser:-$ed}" south
    else
      log place "place($trigger): rebuild side-by-side (no editor) — browser | Ghostty"
      [ -n "$browser" ] && [ -n "$gho" ] && warp_to "$gho" "$browser" east
    fi
    yabai -m space "$target" --balance 2>/dev/null
  fi

  # Sweep pre-existing strays under the editor (adopt carries all the guards,
  # including the no-editor bail, so this is safe when no editor is open).
  # The tail-of-pipe subshell isolates adopt's var reassignments (target/ed/id)
  # from this function — keep the loop in the pipeline and keep it last.
  yabai -m query --windows --space "$target" 2>/dev/null \
    | jq -r '.[]|select(.subrole=="AXStandardWindow" and ."is-floating"==false)|.id' \
    | while read -r sid; do adopt "$sid"; done
}

# ------------------------------------------------------- display-change gate
# Re-place editors only when the set of displays actually changed (dock/undock
# or resolution change), ignoring the duplicate/spurious events a dock fires.
on_display_change() {
  LOCK=/tmp/yabai_display.lock
  if ! mkdir "$LOCK" 2>/dev/null; then log dpy "display-change: locked-skip"; return; fi
  trap 'rmdir "$LOCK" 2>/dev/null' EXIT
  sig=$(yabai -m query --displays 2>/dev/null | jq -Sc '[.[]|{w:(.frame.w|floor),h:(.frame.h|floor)}]|sort_by(.w,.h)')
  prev=$(cat "$SIG_FILE" 2>/dev/null)
  log dpy "display-change: sig=$sig prev=$prev"
  [ -z "$sig" ] && { log dpy "  empty query, skip"; return; }
  [ "$sig" = "$prev" ] && { log dpy "  no change, skip"; return; }
  printf '%s' "$sig" > "$SIG_FILE"
  place_editors display-change
}

# SA capability — computed once before the dispatch case below. It no longer
# gates place_editors' rebuild; it now only gates load-time SA setup
# (--load-sa, dock_did_restart) and the startup space --focus 3.
if sa_capable; then HAS_SA=1; else HAS_SA=0; fi

# ----------------------------------------------------- dispatch (signal calls)
case "$1" in
  display-change) on_display_change; exit 0 ;;
  place)          place_editors "${2:-window}"; exit 0 ;;
  adopt)          adopt "$2"; exit 0 ;;
esac

# ============================================================ yabai load (no arg)
log load "config loading"

# Scripting addition: load only if SIP allows it; otherwise run tiling-only.
if [ "$HAS_SA" = 1 ]; then
  log load "scripting addition available — full mode"
  sudo yabai --load-sa
  yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
else
  log load "no scripting addition (SIP on) — tiling-only mode"
fi

yabai -m config menubar_opacity 0.0
yabai -m config external_bar all:0:0

# Space 2 = chaos zone. float layout means yabai tiles NOTHING here — every
# window floats wherever you drop it. Declared before the bsp default so a
# restart can't tile its windows first. Which apps land here is left to macOS
# (Dock → right-click → Options → Assign To).
yabai -m config --space 2 layout float

yabai -m config layout bsp
yabai -m config window_placement second_child

# Gaps
yabai -m config top_padding 6
yabai -m config bottom_padding 16
yabai -m config left_padding 12
yabai -m config right_padding 12
yabai -m config window_gap 10

# Mouse
yabai -m config mouse_follows_focus off
yabai -m config focus_follows_mouse autofocus
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# Window rules
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Finder$" title="^(Copy|Move|Delete|Connecting)" manage=off
yabai -m rule --add app="^Logi Options\+$" manage=off
yabai -m rule --add app="^Herd$" manage=off
yabai -m rule --add app="^Zed$" title="Settings$" manage=off
# Lowercase "ghostty" is a roleless phantom helper window; case-sensitive so it
# never matches the real "Ghostty".
yabai -m rule --add app="^ghostty$" manage=off
yabai -m rule --add title="^Picture-in-Picture$" manage=off
yabai -m rule --add app="^TV$" manage=off
yabai -m rule --add app="^LilyView$" manage=off
yabai -m query --windows | jq -r '.[]|select((.app=="TV" or .title=="Picture-in-Picture") and ."is-floating"==false)|.id' \
  | xargs -I{} yabai -m window {} --toggle float

# App->desktop assignment is left to macOS (Dock → Assign To). rule --apply
# still re-floats the manage=off windows (System Settings, ghostty phantom, TV).
yabai -m rule --apply

# Rebalance BSP when a window closes (works without the scripting addition)
yabai -m signal --add event=window_destroyed action="yabai -m space --balance"

# Cross-space + editor placement. `window --space` works SIP-on (yabai 7.1.25)
# and the layout rebuild is warp-based (tree-only), so placement runs fully in
# both modes. Only `space --focus` still needs the SA — just the startup focus
# below remains gated.
yabai -m signal --add event=display_added   action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=display_removed action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=display_resized action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=display_moved   action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=window_destroyed app="$EDITOR_RE" action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m signal --add event=window_created app="$BROWSER_RE"  action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m signal --add event=window_created app="$EDITOR_RE"   action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m signal --add event=window_created app="^Ghostty$"    action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m signal --add event=window_created action="\$HOME/Code/dotfiles/mac/yabai/yabairc adopt \$YABAI_WINDOW_ID"
yabai -m query --displays 2>/dev/null | jq -Sc '[.[]|{w:(.frame.w|floor),h:(.frame.h|floor)}]|sort_by(.w,.h)' > "$SIG_FILE"
place_editors startup
# Startup focus of the editor space needs the SA; under SIP-on switch with ^3.
[ "$HAS_SA" = 1 ] && yabai -m space --focus 3
log load "config loaded"
echo "yabai configuration loaded"
