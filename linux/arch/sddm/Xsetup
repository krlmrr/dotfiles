#!/bin/sh
# Xsetup - run as root before the login dialog appears

# If Studio Display is connected on DP-1, use it as primary
if xrandr | grep -q "^DP-1 connected"; then
    xrandr --output DP-1 --mode 3840x2160 --rate 60 --primary \
           --output eDP-1 --mode 1920x1080 --rate 60 --right-of DP-1 \
           --output DP-2 --off
fi
