#!/usr/bin/env sh
# Single-file yabai config + dynamic layout. Invoked two ways:
#   • no arg  → yabai runs this on load: full config + signal registration
#   • "<cmd>" → signal actions re-invoke this file to run one function
# Everything logs to /tmp/yabai.log so there's one place to watch.

LOG=/tmp/yabai.log
SELF="$HOME/Code/dotfiles/mac/yabai/yabairc"
LAPTOP_W=2056          # MBP 16" reports 2056x1329 in yabai points; used to
LAPTOP_H=1329          # tell the laptop panel from an external display.
SIG_FILE=/tmp/yabai_display_sig

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') [$1] ${2:-}" >> "$LOG"; }

# True when the scripting addition can load (SIP off, or the partial config with
# filesystem protections disabled). Full SIP -> false -> tiling-only mode.
sa_capable() {
  s=$(csrutil status 2>/dev/null)
  echo "$s" | grep -qi 'status: disabled' && return 0
  echo "$s" | grep -qi 'Filesystem Protections: disabled'
}

# ------------------------------------------------------------------ helpers
move() {  # move every window of app $1 to space $2 (leaves the sticky PiP popout alone)
  yabai -m query --windows 2>/dev/null \
    | jq -r --arg a "$1" '.[]|select(.app==$a and .title!="Picture-in-Picture")|.id' \
    | xargs -I{} yabai -m window {} --space "$2" 2>/dev/null
}

# The editor set: Zed and VS Code ("Code"). Both are treated interchangeably as
# "the editor" — whichever are open share the editor slot/layout. This jq
# predicate is the single source of truth for "is this window an editor".
editor_sel='(.app=="Zed" or .app=="Code")'

move_editors() {  # move every editor window to space $1 (leaves the sticky PiP popout alone)
  yabai -m query --windows 2>/dev/null \
    | jq -r ".[]|select($editor_sel and .title!=\"Picture-in-Picture\")|.id" \
    | xargs -I{} yabai -m window {} --space "$1" 2>/dev/null
}

editor_ids() {  # ids of all STANDARD editor windows, in query order (first = base)
  yabai -m query --windows 2>/dev/null \
    | jq -r ".[]|select($editor_sel and .subrole==\"AXStandardWindow\" and .title!=\"Picture-in-Picture\")|.id"
}

win_id() {  # id of first STANDARD window of app $1 (exact name; skips phantoms
            # and the "Picture-in-Picture" popout, which reports AXStandardWindow)
  yabai -m query --windows 2>/dev/null \
    | jq -r --arg a "$1" '.[]|select(.app==$a and .subrole=="AXStandardWindow" and .title!="Picture-in-Picture")|.id' | head -1
}
floating()     { yabai -m query --windows --window "$1" 2>/dev/null | jq -r '."is-floating"'; }
ensure_tiled() { [ "$(floating "$1")" = "true" ]  && yabai -m window "$1" --toggle float 2>/dev/null; return 0; }
ensure_float() { [ "$(floating "$1")" = "false" ] && yabai -m window "$1" --toggle float 2>/dev/null; return 0; }

# True when the editor layout already matches the desired target on space $1:
#   editor open  -> Zen-TL / Ghostty-BL (stacked left) / editor full-R
#   editor closed-> Zen | Ghostty side by side (Zen left)
# 0-or-1 editors present is trivially correct (nothing to arrange).
external_correct() {
  yabai -m query --windows --space "$1" 2>/dev/null | jq -e '
      (map(select(.subrole=="AXStandardWindow" and .title!="Picture-in-Picture"))) as $w
    | ($w|map(select(.app=="Zen"))|first)     as $zen
    | ($w|map(select('"$editor_sel"'))|first) as $ed
    | ($w|map(select(.app=="Ghostty"))|first) as $gho
    | ([$zen,$ed,$gho]|map(select(.!=null))|length) as $n
    | if $n <= 1 then true
      elif $ed then
        ($zen and $gho)
        and ($ed.frame.x > $zen.frame.x)
        and (($zen.frame.x|floor) == ($gho.frame.x|floor))
        and ($zen.frame.y < $gho.frame.y)
      else
        ($zen and $gho)
        and ($zen.frame.x < $gho.frame.x)
        and (($zen.frame.y|floor) == ($gho.frame.y|floor))
      end
  ' >/dev/null 2>&1
}

# ------------------------------------------------------------- place editors
# Acts on whichever editors are OPEN (none required). Deterministic --insert
# rebuild; skips entirely when the layout is already correct.
place_editors() {
  trigger="${1:-startup}"
  external_idx=$(yabai -m query --displays 2>/dev/null \
    | jq -r --argjson w "$LAPTOP_W" --argjson h "$LAPTOP_H" \
      '.[]|select(.frame.w!=$w or .frame.h!=$h)|.index' | head -1)

  if [ -z "$external_idx" ]; then
    log place "place($trigger): laptop only -> Zen:3 editors:4 Ghostty:5"
    move Zen 3; move_editors 4; move Ghostty 5
    return
  fi

  target=$(yabai -m query --spaces --display "$external_idx" 2>/dev/null | jq -r '.[2].index // empty')
  [ -z "$target" ] && { log place "place($trigger): external present, no 3rd space"; return; }

  eds=$(editor_ids); ed=$(echo "$eds" | head -1); zen=$(win_id Zen); gho=$(win_id Ghostty)
  for id in $eds $zen $gho; do [ -n "$id" ] && yabai -m window "$id" --space "$target" 2>/dev/null; done

  if external_correct "$target"; then
    log place "place($trigger): already correct on space $target — skip"
    return
  fi

  # The float/reinsert rebuild below needs the target space focused, which
  # requires the SA. Under SIP-on the editors are already moved (above); skip
  # the layout arrange rather than run it blind on a non-visible space.
  if [ "$HAS_SA" != 1 ]; then
    log place "place($trigger): SIP-on — moved to $target, skipping layout rebuild"
    return
  fi

  # Float-then-reinsert build (avoids --warp ambiguity).
  yabai -m space --focus "$target" 2>/dev/null
  if [ -n "$ed" ]; then
    # Editor open -> stacked: editor base (full-right), Zen west, Ghostty south of Zen.
    log place "place($trigger): rebuild stacked (editor open) — Zen TL / Ghostty BL / editor R"
    ensure_tiled "$ed"
    [ -n "$zen" ] && ensure_float "$zen"
    [ -n "$gho" ] && ensure_float "$gho"
    if [ -n "$zen" ]; then yabai -m window "$ed" --insert west 2>/dev/null; ensure_tiled "$zen"; fi
    if [ -n "$gho" ]; then
      anchor="${zen:-$ed}"
      yabai -m window "$anchor" --insert south 2>/dev/null
      ensure_tiled "$gho"
    fi
  else
    # No editor -> side by side: Zen left (base), Ghostty re-tiles east of it.
    log place "place($trigger): rebuild side-by-side (no editor) — Zen | Ghostty"
    [ -n "$zen" ] && ensure_tiled "$zen"
    if [ -n "$gho" ]; then
      ensure_float "$gho"
      [ -n "$zen" ] && yabai -m window "$zen" --insert east 2>/dev/null
      ensure_tiled "$gho"
    fi
  fi
}

# ------------------------------------------------------- display-change gate
# Re-place editors only when the set of displays actually changed (dock/undock
# or resolution change), ignoring the duplicate/spurious events a dock fires.
on_display_change() {
  LOCK=/tmp/yabai_display.lock
  if ! mkdir "$LOCK" 2>/dev/null; then log dpy "display-change: locked-skip"; return; fi
  trap 'rmdir "$LOCK" 2>/dev/null' EXIT
  sig=$(yabai -m query --displays 2>/dev/null | jq -Sc '[.[]|{w:(.frame.w|floor),h:(.frame.h|floor)}]|sort_by(.w,.h)')
  prev=$(cat "$SIG_FILE" 2>/dev/null)
  log dpy "display-change: sig=$sig prev=$prev"
  [ -z "$sig" ] && { log dpy "  empty query, skip"; return; }
  [ "$sig" = "$prev" ] && { log dpy "  no change, skip"; return; }
  printf '%s' "$sig" > "$SIG_FILE"
  place_editors display-change
}

# SA capability — needed in BOTH the signal-dispatch path (place_editors gates
# its focus-dependent rebuild on it) and the main load below, so compute it
# before the dispatch case exits.
if sa_capable; then HAS_SA=1; else HAS_SA=0; fi

# ----------------------------------------------------- dispatch (signal calls)
case "$1" in
  display-change) on_display_change; exit 0 ;;
  place)          place_editors "${2:-window}"; exit 0 ;;
esac

# ============================================================ yabai load (no arg)
log load "config loading"

# Scripting addition: load only if SIP allows it; otherwise run tiling-only.
if [ "$HAS_SA" = 1 ]; then
  log load "scripting addition available — full mode"
  sudo yabai --load-sa
  yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
else
  log load "no scripting addition (SIP on) — tiling-only mode"
fi

yabai -m config menubar_opacity 0.0
yabai -m config external_bar all:0:0

# Space 2 = chaos zone. float layout means yabai tiles NOTHING here — every
# window floats wherever you drop it. Declared before the bsp default so a
# restart can't tile its windows first. Which apps land here is left to macOS
# (Dock → right-click → Options → Assign To).
yabai -m config --space 2 layout float

yabai -m config layout bsp
yabai -m config window_placement second_child

# Gaps
yabai -m config top_padding 6
yabai -m config bottom_padding 16
yabai -m config left_padding 12
yabai -m config right_padding 12
yabai -m config window_gap 10

# Mouse
yabai -m config mouse_follows_focus off
yabai -m config focus_follows_mouse autofocus
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# Window rules
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Finder$" title="^(Copy|Move|Delete|Connecting)" manage=off
yabai -m rule --add app="^Logi Options\+$" manage=off
yabai -m rule --add app="^Herd$" manage=off
yabai -m rule --add app="^Zed$" title="Settings$" manage=off
# Lowercase "ghostty" is a roleless phantom helper window; case-sensitive so it
# never matches the real "Ghostty".
yabai -m rule --add app="^ghostty$" manage=off
yabai -m rule --add title="^Picture-in-Picture$" manage=off
yabai -m rule --add app="^TV$" manage=off
yabai -m rule --add app="^LilyView$" manage=off
yabai -m query --windows | jq -r '.[]|select((.app=="TV" or .title=="Picture-in-Picture") and ."is-floating"==false)|.id' \
  | xargs -I{} yabai -m window {} --toggle float

# App->desktop assignment is left to macOS (Dock → Assign To). rule --apply
# still re-floats the manage=off windows (System Settings, ghostty phantom, TV).
yabai -m rule --apply

# Rebalance BSP when a window closes (works without the scripting addition)
yabai -m signal --add event=window_destroyed action="yabai -m space --balance"

# Cross-space + editor placement. `window --space` works SIP-on (yabai 7.1.25),
# so editors get MOVED to their spaces in both modes. Only `space --focus` still
# needs the SA — the startup focus below and the rebuild inside place_editors
# stay gated; everything else runs unconditionally.
yabai -m signal --add event=display_added   action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=display_removed action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=display_resized action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=display_moved   action="\$HOME/Code/dotfiles/mac/yabai/yabairc display-change"
yabai -m signal --add event=window_destroyed app="^(Zed|Code)$" action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m signal --add event=window_created app="^Zen$"          action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m signal --add event=window_created app="^(Zed|Code)$"   action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m signal --add event=window_created app="^Ghostty$"      action="\$HOME/Code/dotfiles/mac/yabai/yabairc place"
yabai -m query --displays 2>/dev/null | jq -Sc '[.[]|{w:(.frame.w|floor),h:(.frame.h|floor)}]|sort_by(.w,.h)' > "$SIG_FILE"
place_editors startup
# Startup focus of the editor space needs the SA; under SIP-on switch with ^3.
[ "$HAS_SA" = 1 ] && yabai -m space --focus 3
log load "config loaded"
echo "yabai configuration loaded"
